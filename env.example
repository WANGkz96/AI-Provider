PORT=3000
REQUEST_BODY_LIMIT=300mb
SERVER_REQUEST_TIMEOUT_MS=1200000
SERVER_HEADERS_TIMEOUT_MS=1260000

# --- Google Provider ---
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_HTTP_TIMEOUT_MS=1200000
GOOGLE_FILE_ACTIVE_TIMEOUT_MS=1200000
GOOGLE_FILE_POLL_INTERVAL_MS=5000
GOOGLE_MAX_RETRIES=0

# --- Groq Provider ---
GROQ_API_KEY=your_groq_api_key_here

# --- Local Docker Settings ---
DOCKER_HOST_URL=http://localhost

# --- Model Configuration ---
MODEL_GEMMA_3_27B_IT_PROVIDER=google

# New Gemini 3/2.5 Models
MODEL_GEMINI_3_FLASH_PREVIEW_PROVIDER=google
MODEL_GEMINI_2_5_FLASH_PROVIDER=google
MODEL_GEMINI_2_5_FLASH_LITE_PROVIDER=google

# Groq Models
MODEL_QWEN3_32B_PROVIDER=groq
# Note: "openai/" prefix models might need explicit quoting or handling if not standard alphanumeric
# Our config parser handles forward slashes fine in values but keys are derived.
# Let's map clean env keys to specific IDs.
# For complex IDs like 'openai/gpt-oss-120b', the user should use a clean key in ENV 
# and we will need to ensure the ID is passed correctly.
#
# Actually, our config system derives ID from the ENV KEY name:
# MODEL_OPENAI_GPT_OSS_120B_PROVIDER=groq -> ID: openai-gpt-oss-120b
# BUT Groq expects 'openai/gpt-oss-120b'.
# We need a way to map our internal "slugified" ID to the real Provider ID, 
# OR we just rely on the user to use the slugified version in the UI and we map it in the adapter.
#
# STRATEGY: 
# The user asked for specific models. Let's use simple keys and handle mapping in the adapter 
# if the generated ID doesn't match the real one. 
#
# HOWEVER, simpler approach:
# The user puts: MODEL_GPT_OSS_120B_PROVIDER=groq
# The ID becomes: gpt-oss-120b
# The adapter receives: gpt-oss-120b
# We can map specific known aliases in the GroqAdapter if needed, 
# OR we can just ask the user to provide the exact ID in the key if possible (but keys can't have slashes).
#
# Best approach for now: Use a clean ID in env, and if Groq rejects it, we fix it in adapter.
# But actually, 'openai/gpt-oss-120b' is a valid model ID for Groq.
# Let's see if we can just map 'gpt-oss-120b' to 'openai/gpt-oss-120b' inside the adapter for specific cases.

MODEL_GPT_OSS_120B_PROVIDER=groq
MODEL_LLAMA_4_MAVERICK_17B_128E_INSTRUCT_PROVIDER=groq
MODEL_KIMI_K2_INSTRUCT_PROVIDER=groq
MODEL_LLAMA_3_3_70B_VERSATILE_PROVIDER=groq
